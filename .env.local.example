# ── Copy this file to .env.local and fill in your values ──────────────────
# If Supabase vars are missing the app runs in Mock Mode automatically (no DB needed).

NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side Supabase key used by /api/notify (never exposed to the browser).
# Find it: Supabase Dashboard → Settings → API → service_role (secret).
# Add this to Vercel → Settings → Environment Variables for production.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Web Push / VAPID ───────────────────────────────────────────────────────
# Generate once:  npx web-push generate-vapid-keys
#
# NEXT_PUBLIC_VAPID_PUBLIC_KEY  → sent to the browser to create a push subscription
# VAPID_PUBLIC_KEY              → same value, used server-side in /api/notify
# VAPID_PRIVATE_KEY             → secret, server-only, NEVER commit or expose
# VAPID_SUBJECT                 → a mailto: or https: contact URL for the push server
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# ── Optional: donation link ─────────────────────────────────────────────────
# If set, a dismissible donation banner appears in the parent dashboard.
# Use any link: Ko-fi, Buy Me a Coffee, PayPal, etc.
# Leave blank (or remove) to hide the banner completely.
NEXT_PUBLIC_DONATION_URL=

# ── Supabase Edge Function env vars (set in Supabase Dashboard, not here) ──
# VAPID_PUBLIC_KEY        same value as above
# VAPID_PRIVATE_KEY       same value as above
# VAPID_SUBJECT           same value as above
# SUPABASE_SERVICE_ROLE_KEY  auto-injected by Supabase into edge functions
# CRON_SECRET             a random string to authenticate cron calls
#                         e.g.  openssl rand -hex 32
